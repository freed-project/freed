{
  "name": "freed",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "packages/*",
    "skills/*",
    "website"
  ],
  "scripts": {
    "postinstall": "node scripts/patch-automerge.mjs",
    "automation:actors": "node scripts/automation-actors.mjs",
    "automation:control": "node scripts/automation-control.mjs",
    "automation:cutover-kernel-guards": "node scripts/automation-kernel-guard-cutover.mjs",
    "automation:repair-outcome-ledger": "node scripts/outcome-ledger-repair.mjs",
    "build": "node scripts/run-workspace-fanout.mjs build",
    "canary:context": "node scripts/canary-context.mjs",
    "dev": "node scripts/run-workspace-fanout.mjs dev",
    "governance:rulesets": "node scripts/sync-github-rulesets.mjs",
    "friends:galaxy-lab": "vite packages/ui/labs/friends-galaxy --host 127.0.0.1",
    "lint": "node scripts/run-workspace-fanout.mjs lint",
    "nightly:self-improve": "node scripts/nightly-self-improve.mjs",
    "session:clean": "bash scripts/dev-session-clean.sh",
    "social:scrape-loop": "node scripts/social-scrape-loop.mjs",
    "stability:artifact": "node scripts/stability-artifact.mjs",
    "test": "node scripts/run-workspace-fanout.mjs test",
    "test:friends-galaxy-lab": "vitest run packages/ui/labs/friends-galaxy/*.test.ts",
    "test:scripts": "bash -n scripts/*.sh scripts/lib/*.sh && node --test $(find scripts -maxdepth 1 -name '*.test.mjs' ! -name 'automation-control.test.mjs' ! -name 'automation-kernel-guard-cutover.test.mjs' -print | sort) && node --test scripts/automation-control.test.mjs && node --test scripts/automation-kernel-guard-cutover.test.mjs",
    "typecheck": "node scripts/run-workspace-fanout.mjs typecheck",
    "typecheck:friends-galaxy-lab": "tsc -p packages/ui/labs/friends-galaxy/tsconfig.json",
    "typecheck:graph": "tsc --build --dry",
    "validate:automations": "node scripts/validate-automation-specs.mjs",
    "validate:host-automations": "node scripts/validate-host-automations.mjs",
    "validate:roadmap": "node scripts/validate-roadmap-status.mjs",
    "validate:skills": "node scripts/validate-skills.mjs",
    "validate:feature": "node scripts/validate-worktree.mjs --mode feature",
    "validate:providers": "node scripts/validate-worktree.mjs --mode providers",
    "validate:dev": "node scripts/validate-worktree.mjs --mode dev",
    "validate:production": "node scripts/validate-worktree.mjs --mode production",
    "validate:release": "node scripts/validate-worktree.mjs --mode release"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
