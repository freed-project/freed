{
  "schemaVersion": 1,
  "id": "freed-nightly-runner",
  "name": "Freed nightly executor",
  "kind": "cron",
  "promptPath": "automation/prompts/freed-nightly-runner.md",
  "authority": "merge-safe",
  "providerBehavior": "approval-required",
  "maxBehavioralChangesPerSoak": 1,
  "stateRoot": "~/.freed/automation",
  "lease": { "name": "nightly-writer", "maxLifetimeMs": 1800000 },
  "localOverlayFields": [
    "status",
    "rrule",
    "model",
    "reasoning_effort",
    "execution_environment",
    "target",
    "cwds"
  ],
  "requiredHostCapabilities": [
    "trusted-launcher",
    "short-lived-credential-handoff"
  ]
}
