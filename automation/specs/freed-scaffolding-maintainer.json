{
  "schemaVersion": 1,
  "id": "freed-scaffolding-maintainer",
  "name": "Freed scaffolding maintainer",
  "kind": "cron",
  "promptPath": "automation/prompts/freed-scaffolding-maintainer.md",
  "authority": "pr-only",
  "providerBehavior": "forbidden",
  "maxBehavioralChangesPerSoak": 0,
  "stateRoot": "~/.freed/automation",
  "lease": { "name": "scaffolding-writer", "maxLifetimeMs": 1800000 },
  "localOverlayFields": [
    "status",
    "rrule",
    "model",
    "reasoning_effort",
    "execution_environment",
    "target",
    "cwds"
  ],
  "requiredHostCapabilities": ["trusted-launcher", "short-lived-lease-handoff"]
}
