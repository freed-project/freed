# Brevo API credentials (for local development with `vercel dev`)
# Get your API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key

# Your Brevo contact list ID (number)
# Find it in the URL when viewing your list in Brevo
BREVO_LIST_ID=123

# Cloudflare Turnstile keys for newsletter signup protection
# Site key is safe for the browser. Secret key must stay server-side.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
