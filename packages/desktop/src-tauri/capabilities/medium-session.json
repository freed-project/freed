{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "medium-session",
  "description": "Allows the hidden Medium WebView to emit capture results to Freed",
  "windows": ["medium-scraper"],
  "remote": {
    "urls": ["https://medium.com/*", "https://www.medium.com/*"]
  },
  "permissions": ["core:event:allow-emit"]
}
